# Mutt configuration for monitor role (read-only observer)
# Multi-Model Messaging System

# Maildir settings
set mbox_type = Maildir
set folder = ".messages"
set spoolfile = "+monitor"
set record = "+.sent"
set postponed = "+monitor"

# Mailboxes to monitor
mailboxes +monitor +coordinator +claude +gpt-5 +gemini +grok

# Identity
set from = "monitor@multimodel.local"
set realname = "Monitor (Observer)"
set use_from = yes

# Sorting and threading
set sort = threads
set sort_aux = reverse-last-date-received
set strict_threads = yes

# UI settings
set pager_index_lines = 10
set pager_context = 3
set menu_scroll = yes
set markers = no
set smart_wrap = yes

# Header display
ignore *
unignore from: to: cc: date: subject: message-id: in-reply-to: x-role: x-artifacts: x-imported:
hdr_order from: to: cc: date: subject: x-role: x-artifacts: x-imported:

# Index format - show role and conversation flow
set index_format = "%4C %Z %{%b %d %H:%M} %-12.12L -> %-12.12t %s"

# Status bar with read-only indicator
set status_format = "-%r-Mutt [READ-ONLY]: %f [Msgs:%?M?%M/?%m%?n? New:%n?%?o? Old:%o?%?d? Del:%d?%?F? Flag:%F?%?t? Tag:%t?%?p? Post:%p?%?b? Inc:%b?%?l? %l?]---(%s/%S)-%>-(%P)---"

# Colors
color normal white default
color indicator black yellow
color status black yellow
color tree brightmagenta default
color index brightyellow default ~N
color index brightred default ~F
color index brightcyan default "~f coordinator"
color index brightgreen default "~f gpt-5"
color index brightblue default "~f claude"
color index magenta default "~f gemini"
color index cyan default "~f grok"
color header brightcyan default "^(From|To|Cc):"
color header brightgreen default "^Subject:"
color header cyan default "^X-Role:"
color header yellow default "^X-Artifacts:"
color header red default "^X-Imported:"

# Key bindings
bind index,pager \Cb previous-page
bind index,pager \Cf next-page
bind index,pager R group-reply
bind index <space> collapse-thread
# Note: Use = for first message, * for last message (mutt defaults)

# Macro to view artifacts
macro index,pager A "<pipe-message>grep '^X-Artifacts:' | cut -d' ' -f2-<enter>" "Show artifacts"

# Macro to view full headers
macro index,pager H "<display-toggle-weed>" "Toggle full headers"

# Enable threading
set collapse_unread = no
set uncollapse_jump = yes

# Date format
set date_format = "%m/%d %H:%M"

# Disable modifications in read-only mode
# Note: This is advisory - actual read-only enforcement comes from mutt -R flag
set confirmappend = no
set move = no
set copy = no

# Editor for composing (disabled for monitor)
set editor = "false"
